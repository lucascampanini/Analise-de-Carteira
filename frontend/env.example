# Firebase — copie este arquivo para .env.local e preencha com os valores do seu projeto
# Console: https://console.firebase.google.com → seu projeto → Configurações → Aplicativos Web

NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=seu-projeto
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# Opcional — só necessário para dev local fora do GitHub Pages
# NEXT_PUBLIC_BASE_PATH=
