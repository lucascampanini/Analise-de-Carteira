{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(pip install *)",
      "Bash(pip freeze *)",
      "Bash(pytest *)",
      "Bash(ruff *)",
      "Bash(mypy *)",
      "Bash(black *)",
      "Bash(isort *)",
      "Bash(docker compose *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(python -m *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Read(.env)",
      "Read(.env.*)",
      "Edit(.env)",
      "Edit(.env.*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python \"C:/Users/lucas/Desktop/Analise-de-Carteira/.claude/hooks/post_write.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"\nimport os, sys\ncmd = os.environ.get('CLAUDE_TOOL_INPUT_COMMAND', '')\n# Bloqueia comandos destrutivos nao autorizados\ndangerous = ['git push --force', 'git reset --hard', 'DROP TABLE', 'DELETE FROM']\nfor d in dangerous:\n    if d.lower() in cmd.lower():\n        print(f'BLOQUEADO: comando perigoso detectado: {d}', file=sys.stderr)\n        sys.exit(1)\n\""
          }
        ]
      }
    ]
  }
}
