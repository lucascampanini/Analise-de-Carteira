rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Bloqueio padrão ────────────────────────────────────────────────────────
    // Nega acesso a QUALQUER caminho não mapeado explicitamente abaixo.
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Helpers ────────────────────────────────────────────────────────────────
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function notTooManyKeys(max) {
      return request.resource.data.keys().size() <= max;
    }

    // ── Dados do usuário ───────────────────────────────────────────────────────
    // Regra principal: cada usuário acessa apenas seus próprios dados.
    // As regras por coleção abaixo adicionam validações de campo.
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // Clientes — campos obrigatórios: codigo_conta + nome
      match /clientes/{docId} {
        allow read:          if isOwner(userId);
        allow delete:        if isOwner(userId);
        allow create, update: if isOwner(userId)
          && request.resource.data.keys().hasAll(['codigo_conta', 'nome'])
          && request.resource.data.codigo_conta is string
          && request.resource.data.codigo_conta.size() > 0
          && request.resource.data.nome is string
          && request.resource.data.nome.size() > 0
          && notTooManyKeys(60);
      }

      // Posições — campo obrigatório: codigo_conta
      match /posicoes/{docId} {
        allow read:          if isOwner(userId);
        allow delete:        if isOwner(userId);
        allow create, update: if isOwner(userId)
          && request.resource.data.keys().hasAll(['codigo_conta'])
          && request.resource.data.codigo_conta is string
          && notTooManyKeys(10);
      }

      // Leads — campo obrigatório: nome
      match /leads/{docId} {
        allow read:          if isOwner(userId);
        allow delete:        if isOwner(userId);
        allow create, update: if isOwner(userId)
          && request.resource.data.keys().hasAll(['nome'])
          && request.resource.data.nome is string
          && request.resource.data.nome.size() > 0
          && notTooManyKeys(40);
      }

      // Anotações — campos obrigatórios: codigo_conta, tipo, texto
      match /anotacoes/{docId} {
        allow read:   if isOwner(userId);
        allow delete: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasAll(['codigo_conta', 'tipo', 'texto'])
          && request.resource.data.texto is string
          && request.resource.data.texto.size() <= 10000
          && notTooManyKeys(10);
        allow update: if isOwner(userId)
          && notTooManyKeys(10);
      }

      // Eventos / tarefas — campo obrigatório: data_evento
      match /eventos/{docId} {
        allow read:          if isOwner(userId);
        allow delete:        if isOwner(userId);
        allow create, update: if isOwner(userId)
          && request.resource.data.keys().hasAll(['data_evento'])
          && notTooManyKeys(15);
      }

      // Reuniões — campo obrigatório: data_hora
      match /reunioes/{docId} {
        allow read:          if isOwner(userId);
        allow delete:        if isOwner(userId);
        allow create, update: if isOwner(userId)
          && request.resource.data.keys().hasAll(['data_hora'])
          && notTooManyKeys(15);
      }

      // Ofertas
      match /ofertas/{docId} {
        allow read, delete:  if isOwner(userId);
        allow create, update: if isOwner(userId)
          && notTooManyKeys(25);
      }

      // Oferta × Clientes
      match /oferta_clientes/{docId} {
        allow read, delete:  if isOwner(userId);
        allow create, update: if isOwner(userId)
          && notTooManyKeys(20);
      }

      // Fundos — campo obrigatório: cnpj
      match /fundos_info/{docId} {
        allow read:          if isOwner(userId);
        allow delete:        if isOwner(userId);
        allow create, update: if isOwner(userId)
          && notTooManyKeys(40);
      }

      // Configurações (supernova, etc.)
      match /config/{docId} {
        allow read, delete:  if isOwner(userId);
        allow create, update: if isOwner(userId)
          && notTooManyKeys(50);
      }
    }
  }
}
