# Analise de Carteira - Variaveis de Ambiente
# Copie para .env e preencha os valores

# Application
BOT_APP_NAME=Analise de Carteira
BOT_DEBUG=false
BOT_ENVIRONMENT=development

# Database PostgreSQL
BOT_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/analise_carteira

# APIs Externas
BOT_BRAPI_TOKEN=seu_token_brapi_aqui
BOT_ANTHROPIC_API_KEY=sua_chave_anthropic_aqui

# Telegram Bot — token obtido via @BotFather no Telegram
BOT_TELEGRAM_BOT_TOKEN=

# yfinance
BOT_YFINANCE_PERIOD_DAYS=252

# Server
BOT_HOST=0.0.0.0
BOT_PORT=8080

# ============================================================
# ASSISTENTE MODULE
# ============================================================

# Evolution API (WhatsApp)
# Instalar: docker run -p 8080:8080 atendai/evolution-api
# Docs: https://doc.evolution-api.com
BOT_EVOLUTION_API_URL=http://localhost:8081
BOT_EVOLUTION_API_KEY=sua_api_key_evolution
BOT_EVOLUTION_INSTANCE_NAME=assessor
BOT_WHATSAPP_NUMERO_ASSESSOR=5511999999999  # seu número (só dígitos, com DDI+DDD)

# Microsoft Graph API (Outlook Calendar)
# Registrar app em portal.azure.com > Azure AD > App registrations
# Permissão necessária: Calendars.ReadWrite (Application)
BOT_MS_TENANT_ID=seu_tenant_id_azure
BOT_MS_CLIENT_ID=seu_client_id_azure
BOT_MS_CLIENT_SECRET=seu_client_secret_azure
BOT_MS_USER_EMAIL=lucas@svninvestimentos.com.br
